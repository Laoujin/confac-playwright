# Test environment configuration
# Copy this to confac/backend/.env when running tests locally

# Environment
ENVIRONMENT=test
BUILD_VERSION=test

# Logging
LOGGING_FILE=./logs
LOGGING_LOKI_NETWORK=false
LOGGING_LOKI=

# MongoDB (using test container on port 27018)
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_USERNAME=admin
MONGO_PASSWORD=pwd
MONGO_DB=confac-test

# App
SERVER_HOST=localhost
PORT=9000
SERVER_BASE_PATH=
ENABLE_ROOT_TEMPLATES=0

# Mock Services
EXCEL_SERVICE_URL=http://localhost:3300
BILLIT_API_URL=http://localhost:3002/v1
BILLIT_API_KEY=test-api-key
BILLIT_PARTY_ID=test-party-id
BILLIT_WEBHOOK_ORDER_CREATED_SECRET=test-secret
BILLIT_WEBHOOK_ORDER_UPDATED_SECRET=test-secret
BILLIT_WEBHOOK_MESSAGE_CREATED_SECRET=test-secret
BILLIT_WEBHOOK_MESSAGE_UPDATED_SECRET=test-secret

# Email (disabled for tests)
EMAIL_USER=
EMAIL_PASS=

# Security - simplified for tests (no Google auth)
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
GOOGLE_DOMAIN=
JWT_SECRET=test-jwt-secret-for-playwright
JWT_EXPIRES=18000
SUPERUSER=admin@confac.test
DEFAULT_ROLE=admin
